# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/ai-blog

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# JWT Expiry
JWT_EXPIRE=7d

# Server Port
PORT=5000

# Frontend URL (used for CORS and OAuth callback redirects)
CLIENT_URL=http://localhost:5173

# Groq API Key
GROQ_API_KEY=your-groq-api-key-here

# LinkedIn OAuth (required for per-user posting)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/linkedin/callback
LINKEDIN_SCOPES=openid profile w_member_social

# Optional cache timing controls
LINKEDIN_OAUTH_STATE_TTL_SECONDS=600
LINKEDIN_TOKEN_EXPIRY_SKEW_SECONDS=60

# Deprecated static LinkedIn posting vars (no longer used)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=

# Instagram Graph API (for posting)
INSTAGRAM_ACCESS_TOKEN=your-instagram-graph-access-token
INSTAGRAM_USER_ID=your-instagram-business-user-id
INSTAGRAM_DEFAULT_IMAGE_URL=https://example.com/default-blog-image.jpg

# Node Environment
NODE_ENV=development
